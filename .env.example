# MongoDB Connection String
# 
# Local development (if using local MongoDB):
# MONGO_URI=mongodb://localhost:27017
#
# MongoDB Atlas (cloud - RECOMMENDED):
# 1. Create a cluster on MongoDB Atlas (mongodb.com)
# 2. Create a database user with username and password
# 3. Get your connection string from "Connect" > "Drivers" > "Node.js"
# 4. Replace with your actual credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# IMPORTANT: Make sure your IP is whitelisted in MongoDB Atlas Network Access
#
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nathan_ana_wedding?retryWrites=true&w=majority

# Server port (optional, default is 3000)
PORT=3000

# Node environment (optional, default is production)
NODE_ENV=production
